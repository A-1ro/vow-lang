{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Kei",
  "scopeName": "source.kei",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#module-decl" },
    { "include": "#import-decl" },
    { "include": "#declaration-binding" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#builtin-types" },
    { "include": "#constructors" },
    { "include": "#property-access" },
    { "include": "#types" },
    { "include": "#label" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.kei",
          "match": "//.*$",
          "captures": {
            "0": { "name": "punctuation.definition.comment.kei" }
          }
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.kei",
      "begin": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.kei" }
      },
      "end": "\"|$",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.kei" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.kei",
          "match": "\\\\[ntr\\\\\"]"
        },
        {
          "name": "invalid.illegal.unknown-escape.kei",
          "match": "\\\\."
        }
      ]
    },
    "module-decl": {
      "match": "\\b(module)\\s+([a-z_][A-Za-z0-9_.]*)",
      "captures": {
        "1": { "name": "keyword.control.import.module.kei" },
        "2": { "name": "entity.name.namespace.kei" }
      }
    },
    "import-decl": {
      "match": "\\b(import)\\s+([a-z_][A-Za-z0-9_.]*)",
      "captures": {
        "1": { "name": "keyword.control.import.kei" },
        "2": { "name": "entity.name.namespace.kei" }
      }
    },
    "declaration-binding": {
      "patterns": [
        {
          "match": "\\b(func)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.function.kei" },
            "2": { "name": "entity.name.function.kei" }
          }
        },
        {
          "match": "\\b(type|record|enum)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.kei" },
            "2": { "name": "entity.name.type.kei" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kei",
          "match": "\\b(if|else|return|fail)\\b"
        },
        {
          "name": "keyword.control.contract.kei",
          "match": "\\b(uses|requires|ensures|implies)\\b"
        },
        {
          "name": "storage.type.kei",
          "match": "\\b(module|import|type|record|enum|func|let)\\b"
        },
        {
          "name": "keyword.other.kei",
          "match": "\\b(as|tagged)\\b"
        },
        {
          "name": "support.function.builtin.old.kei",
          "match": "\\bold\\b(?=\\s*\\()"
        },
        {
          "name": "variable.language.result.kei",
          "match": "\\bresult\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.kei",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.integer.kei",
      "match": "\\b[0-9]+\\b"
    },
    "builtin-types": {
      "name": "support.type.builtin.kei",
      "match": "\\b(Int|Bool|String|Result|Option)\\b"
    },
    "constructors": {
      "name": "support.function.constructor.kei",
      "match": "\\b(Some|None|Ok|Err)\\b"
    },
    "property-access": {
      "match": "(\\.)([a-z_][A-Za-z0-9_]*)\\b(?!\\s*\\()",
      "captures": {
        "1": { "name": "punctuation.accessor.dot.kei" },
        "2": { "name": "variable.other.property.kei" }
      }
    },
    "types": {
      "name": "entity.name.type.kei",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
    },
    "label": {
      "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?=:)",
      "captures": {
        "1": { "name": "variable.other.property.kei" }
      }
    },
    "function-call": {
      "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.kei" }
      }
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.arrow.kei", "match": "->" },
        { "name": "keyword.operator.comparison.kei", "match": "==|!=|<=|>=|<|>" },
        { "name": "keyword.operator.assignment.kei", "match": "=" },
        { "name": "keyword.operator.arithmetic.kei", "match": "[+\\-*/]" },
        { "name": "keyword.operator.logical.kei", "match": "!" }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.section.braces.kei", "match": "[{}]" },
        { "name": "punctuation.section.parens.kei", "match": "[()]" },
        { "name": "punctuation.section.brackets.kei", "match": "[\\[\\]]" },
        { "name": "punctuation.separator.comma.kei", "match": "," },
        { "name": "punctuation.separator.colon.kei", "match": ":" },
        { "name": "punctuation.accessor.dot.kei", "match": "\\." }
      ]
    }
  }
}
