{
  "permissions": {
    "allow": [
      "Edit(docs/dev-notes/**)",
      "Write(docs/dev-notes/**)",
      "Workflow(kei-code-review)",
      "mcp__github__pull_request_review_write",
      "mcp__github__add_comment_to_pending_review",
      "Edit(crates/**)",
      "Write(crates/**)",
      "Edit(runtime/**)",
      "Write(runtime/**)",
      "Edit(.claude/hooks/**)",
      "Write(.claude/hooks/**)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git restore:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-ci.sh",
            "if": "Bash(git commit*)",
            "timeout": 300,
            "statusMessage": "Running pre-commit CI (fmt / clippy / test)…"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "agent",
            "prompt": "Read the file .claude/hooks/post-merge-lessons.prompt.md and follow its instructions exactly. Append your findings to docs/dev-notes/lessons-from-reviews.md. Do not commit, push, or modify any other file. Hook input JSON: $ARGUMENTS",
            "model": "claude-sonnet-4-6",
            "if": "Bash(gh pr merge*)",
            "timeout": 180,
            "statusMessage": "Extracting post-merge lessons (Sonnet)…"
          },
          {
            "type": "agent",
            "prompt": "Read the file .claude/hooks/post-merge-handoff.prompt.md and follow its instructions exactly. Append your findings to docs/dev-notes/handoff-candidates.md. Do not commit, push, or modify any other file (especially not HANDOFF.md itself). Hook input JSON: $ARGUMENTS",
            "model": "claude-sonnet-4-6",
            "if": "Bash(gh pr merge*)",
            "timeout": 180,
            "statusMessage": "Extracting post-merge HANDOFF.md candidates (Sonnet)…"
          },
          {
            "type": "agent",
            "prompt": "Read the file .claude/hooks/post-pr-create-review.prompt.md and follow its instructions exactly. Do not commit, push, or modify any file. Hook input JSON: $ARGUMENTS",
            "model": "claude-sonnet-4-6",
            "if": "Bash(gh pr create*)",
            "timeout": 1800,
            "statusMessage": "Running kei-code-review on the new PR (high)…"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start-learnings.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
